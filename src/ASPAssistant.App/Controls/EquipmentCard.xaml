<UserControl x:Class="ASPAssistant.App.Controls.EquipmentCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ASPAssistant.App.Converters">
    <UserControl.Resources>
        <converters:TierToRomanConverter x:Key="TierToRoman" />
    </UserControl.Resources>

    <Border Style="{StaticResource ItemCardBorder}">
        <StackPanel>
            <!-- Header: icon left | right side stacks name+toggle above track button -->
            <DockPanel>
                <!-- Icon (left, top-aligned) -->
                <Border DockPanel.Dock="Left" Width="72" Height="72" Margin="0,0,8,0"
                        CornerRadius="4" Background="#22FFFFFF" VerticalAlignment="Top"
                        ClipToBounds="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=EliteToggle}" Value="True">
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="BorderBrush" Value="#FFD700" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image x:Name="IconImage" Stretch="UniformToFill" />
                </Border>

                <!-- Right side -->
                <StackPanel VerticalAlignment="Top">
                    <!-- Row 1: tier + name + toggle, all top-aligned -->
                    <DockPanel>
                        <Border DockPanel.Dock="Right" CornerRadius="9"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Background="#1A4FC3F7" Padding="2" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="NormalToggle" Content="普通"
                                              IsChecked="True"
                                              Style="{StaticResource VariantToggleButton}"
                                              Click="OnNormalClick" />
                                <ToggleButton x:Name="EliteToggle" Content="精锐"
                                              Style="{StaticResource VariantToggleButton}"
                                              Click="OnEliteClick" />
                            </StackPanel>
                        </Border>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding Tier, Converter={StaticResource TierToRoman}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,5,0"
                                   VerticalAlignment="Top" />
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Top" />
                    </DockPanel>

                    <!-- Row 2: track button -->
                    <Button x:Name="TrackButton" HorizontalAlignment="Right"
                            Style="{StaticResource TrackingButton}"
                            Margin="0,6,0,0" Click="OnTrackClick" />
                </StackPanel>
            </DockPanel>

            <TextBlock x:Name="EffectText" Margin="0,4,0,0"
                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
