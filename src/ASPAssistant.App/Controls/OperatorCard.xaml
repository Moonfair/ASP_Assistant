<UserControl x:Class="ASPAssistant.App.Controls.OperatorCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ASPAssistant.App.Converters">
    <UserControl.Resources>
        <converters:TierToRomanConverter x:Key="TierToRoman" />
    </UserControl.Resources>

    <Border Style="{StaticResource ItemCardBorder}">
        <StackPanel>
            <!-- Header: icon + name + variant toggle -->
            <DockPanel>
                <!-- Variant pill toggle (right-aligned) -->
                <Border DockPanel.Dock="Right" CornerRadius="9"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Background="#1A4FC3F7" Padding="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="NormalToggle" Content="普通"
                                      IsChecked="True"
                                      Style="{StaticResource VariantToggleButton}"
                                      Click="OnNormalClick" />
                        <ToggleButton x:Name="EliteToggle" Content="精锐"
                                      Style="{StaticResource VariantToggleButton}"
                                      Click="OnEliteClick" />
                    </StackPanel>
                </Border>

                <!-- Icon placeholder + tier + name -->
                <Border DockPanel.Dock="Left" Width="36" Height="36" Margin="0,0,8,0"
                        CornerRadius="4" Background="#22FFFFFF" VerticalAlignment="Center"
                        ClipToBounds="True">
                    <Image x:Name="IconImage" Stretch="UniformToFill" />
                </Border>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Tier, Converter={StaticResource TierToRoman}}"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" FontSize="13" Margin="0,0,5,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Covenants -->
            <WrapPanel Margin="0,6,0,0">
                <Border CornerRadius="8" Background="#224FC3F7"
                        Padding="6,1" Margin="0,0,4,0">
                    <TextBlock Text="{Binding CoreCovenant}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11" />
                </Border>
                <ItemsControl ItemsSource="{Binding AdditionalCovenants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Background="#14FFFFFF"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="6,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>

            <!-- Traits -->
            <ItemsControl x:Name="TraitsPanel" Margin="0,6,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,4">
                            <!-- Trait type chip -->
                            <Border Style="{StaticResource TraitTagBorder}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TraitType}"
                                           FontSize="10" Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <!-- Trait description -->
                            <TextBlock Text="{Binding TraitDescription}"
                                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Track button -->
            <Button x:Name="TrackButton" HorizontalAlignment="Right"
                    Style="{StaticResource TrackingButton}"
                    Margin="0,6,0,0" Click="OnTrackClick" />
        </StackPanel>
    </Border>
</UserControl>
