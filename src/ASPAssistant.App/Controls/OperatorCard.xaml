<UserControl x:Class="ASPAssistant.App.Controls.OperatorCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ASPAssistant.App.Converters">
    <UserControl.Resources>
        <converters:TierToRomanConverter x:Key="TierToRoman" />
    </UserControl.Resources>

    <Border x:Name="CardBorder" Style="{StaticResource ItemCardBorder}">
        <StackPanel>
            <!-- Header: icon left | right side stacks name+toggle above track button -->
            <DockPanel>
                <!-- Icon (left, top-aligned) with ban badge overlay -->
                <Grid DockPanel.Dock="Left" Width="72" Height="72" Margin="0,0,8,0"
                      VerticalAlignment="Top">
                    <Border CornerRadius="4" Background="#22FFFFFF" ClipToBounds="True">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=EliteToggle}" Value="True">
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter Property="BorderBrush" Value="#FFD700" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Image x:Name="IconImage" Stretch="UniformToFill" />
                    </Border>
                    <!-- Ban overlay: dim layer -->
                    <Border x:Name="BanDimOverlay" CornerRadius="4"
                            Background="#88000000" Visibility="Collapsed" />
                    <!-- Ban badge: "禁用" chip in bottom-right corner -->
                    <Border x:Name="BanBadge" CornerRadius="4,0,4,0"
                            Background="#CCDD2222" Padding="4,2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Visibility="Collapsed">
                        <TextBlock Text="禁用" FontSize="10" FontWeight="Bold"
                                   Foreground="White" />
                    </Border>
                </Grid>

                <!-- Right side -->
                <StackPanel VerticalAlignment="Top">
                    <!-- Row 1: tier + name + toggle, all top-aligned -->
                    <DockPanel>
                        <Border DockPanel.Dock="Right" CornerRadius="9"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Background="#1A4FC3F7" Padding="2" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="NormalToggle" Content="普通"
                                              IsChecked="True"
                                              Style="{StaticResource VariantToggleButton}"
                                              Click="OnNormalClick" />
                                <ToggleButton x:Name="EliteToggle" Content="精锐"
                                              Style="{StaticResource VariantToggleButton}"
                                              Click="OnEliteClick" />
                            </StackPanel>
                        </Border>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding Tier, Converter={StaticResource TierToRoman}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,5,0"
                                   VerticalAlignment="Top" />
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Top" />
                    </DockPanel>

                    <!-- Row 2: track button -->
                    <Button x:Name="TrackButton" HorizontalAlignment="Right"
                            Style="{StaticResource TrackingButton}"
                            Margin="0,6,0,0" Click="OnTrackClick" />

                    <!-- Row 3: ban toggle button -->
                    <Button x:Name="BanButton" HorizontalAlignment="Right"
                            Style="{StaticResource BanToggleButton}"
                            Margin="0,4,0,0" Click="OnBanClick" />
                </StackPanel>
            </DockPanel>

            <!-- Covenants -->
            <WrapPanel Margin="0,6,0,0">
                <ItemsControl ItemsSource="{Binding CoreCovenants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Background="#224FC3F7"
                                    Padding="6,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding AdditionalCovenants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Background="#14FFFFFF"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="6,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>

            <!-- Traits -->
            <ItemsControl x:Name="TraitsPanel" Margin="0,6,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,4">
                            <!-- Trait type chip -->
                            <Border Style="{StaticResource TraitTagBorder}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TraitType}"
                                           FontSize="10" Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <!-- Trait description -->
                            <TextBlock Text="{Binding TraitDescription}"
                                       FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
