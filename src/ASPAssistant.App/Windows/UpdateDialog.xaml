<Window x:Class="ASPAssistant.App.Windows.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="发现新版本"
        Width="420" SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBackgroundBrush}"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DialogProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF4FC3F7" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Width" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#FF12122A" MouseLeftButtonDown="OnTitleBarDrag">
                <DockPanel>
                    <Button Content="✕" Click="OnClose" DockPanel.Dock="Right"
                            Style="{StaticResource CloseButton}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="↑" Foreground="#FF8BC34A" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="TitleText" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content -->
            <StackPanel DockPanel.Dock="Bottom" Margin="16">
                <!-- Version info -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="当前版本  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="CurrentVersionText" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="最新版本  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="LatestVersionText" Foreground="#FF8BC34A"
                                   FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>

                <!-- Release notes -->
                <TextBlock Text="更新内容" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" />
                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,0,0,14">
                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesText"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11" TextWrapping="Wrap" LineHeight="18" />
                    </ScrollViewer>
                </Border>

                <!-- Progress area -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,14">
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock x:Name="ProgressPercent" DockPanel.Dock="Right"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" Margin="6,0,0,0" />
                        <TextBlock x:Name="StatusText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" Text="正在下载更新..." />
                    </DockPanel>
                    <ProgressBar x:Name="DownloadProgress" Style="{StaticResource DialogProgressBar}"
                                 Value="0" Maximum="100" />
                </StackPanel>

                <!-- Buttons -->
                <DockPanel>
                    <Button x:Name="UpdateButton" DockPanel.Dock="Right" Content="立即更新"
                            Click="OnUpdateClick" Width="90" Height="30"
                            Background="#FF4FC3F7" Foreground="#FF1A1A2E"
                            FontWeight="SemiBold" FontSize="12"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#FF81D4FA" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bg" Property="Background" Value="#FF334155" />
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="DeferButton" Content="稍后提醒" Click="OnDefer"
                            Width="80" Height="30" Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#22FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
