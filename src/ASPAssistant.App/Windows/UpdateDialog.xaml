<Window x:Class="ASPAssistant.App.Windows.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="发现新版本"
        Width="420" SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBackgroundBrush}"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#FF12122A" MouseLeftButtonDown="OnTitleBarDrag">
                <DockPanel>
                    <Button Content="✕" Click="OnClose" DockPanel.Dock="Right"
                            Style="{StaticResource CloseButton}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="↑" Foreground="#FF8BC34A" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="TitleText" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content -->
            <StackPanel DockPanel.Dock="Bottom" Margin="16">
                <!-- Version info -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="当前版本  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="CurrentVersionText" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="最新版本  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="LatestVersionText" Foreground="#FF8BC34A"
                                   FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>

                <!-- Release notes -->
                <TextBlock Text="更新内容" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" />
                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,0,0,14">
                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesText"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11" TextWrapping="Wrap" LineHeight="18" />
                    </ScrollViewer>
                </Border>

                <!-- Hint: download is running in background -->
                <TextBlock x:Name="DownloadHintText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           Text="正在后台下载更新，完成后横幅将显示重启按钮。" />

                <!-- Buttons -->
                <DockPanel HorizontalAlignment="Right">
                    <Button Content="关闭" Click="OnClose"
                            Width="80" Height="30"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#22FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
