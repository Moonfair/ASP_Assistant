<Window x:Class="ASPAssistant.App.Windows.LineupEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ASPAssistant.App.Converters"
        xmlns:models="clr-namespace:ASPAssistant.Core.Models;assembly=ASPAssistant.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="阵容编辑"
        Width="980" Height="660" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource PanelBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="{StaticResource AspaLogo}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:LocalPathToImageConverter x:Key="PathToImage" />

        <Style x:Key="EditorPrimaryButton" TargetType="Button" BasedOn="{StaticResource ClickableButtonBase}">
            <Setter Property="Background" Value="#FF3D6EF5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FF5688FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorSecondaryButton" TargetType="Button" BasedOn="{StaticResource ClickableButtonBase}">
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A small pill-shaped chip used for tags / equipment slots inside slot card -->
        <Style x:Key="ChipButton" TargetType="Button" BasedOn="{StaticResource ClickableButtonBase}">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="#FF1A1A2E" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#FF12122A" MouseLeftButtonDown="OnTitleBarDrag">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="✕" Click="OnCancelClick"
                            Style="{StaticResource CloseButton}" />
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <TextBlock Text="阵容编辑器" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Bottom action bar -->
            <Border DockPanel.Dock="Bottom" Background="#FF12122A" Padding="12,10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="取消" Style="{StaticResource EditorSecondaryButton}"
                                Click="OnCancelClick" Margin="0,0,8,0" />
                        <Button Content="保存" Style="{StaticResource EditorPrimaryButton}"
                                Click="OnSaveClick" />
                    </StackPanel>
                    <TextBlock x:Name="EditorHint"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Body: slots grid + covenant panel -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <!-- Slots grid -->
                <DockPanel Grid.Column="0" Margin="12">
                    <!-- Top: name + summary -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <DockPanel>
                            <Border DockPanel.Dock="Right"
                                    Background="#224FC3F7" CornerRadius="4"
                                    Padding="8,4" VerticalAlignment="Center">
                                <TextBlock x:Name="ActivatedSummaryText"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Text="激活 0 个盟约" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="阵容名" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBox x:Name="LineupNameBox"
                                         Background="#22000000" Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="0,0,0,1"
                                         Padding="2,4" FontSize="14"
                                         CaretBrush="{StaticResource AccentBrush}"
                                         TextChanged="OnLineupNameChanged" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- 9 slot cards in 3x3 grid -->
                    <ItemsControl x:Name="SlotsHost">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <!-- Right: covenant breakdown -->
                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="盟约层数"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="12,10,12,4" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CovenantStatsList" Padding="10,4,10,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,4"
                                                Tag="{Binding Activated}"
                                                Loaded="OnCovenantRowLoaded">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding Count, Mode=OneWay}" />
                                                    <Run Text="/" />
                                                    <Run Text="{Binding ActivateCount, Mode=OneWay, TargetNullValue='?'}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
