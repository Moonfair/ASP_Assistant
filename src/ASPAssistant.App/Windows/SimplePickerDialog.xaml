<Window x:Class="ASPAssistant.App.Windows.SimplePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ASPAssistant.App.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="选择"
        Width="420" Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource PanelBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="{StaticResource AspaLogo}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:LocalPathToImageConverter x:Key="PathToImage" />
    </Window.Resources>
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#FF12122A" MouseLeftButtonDown="OnTitleBarDrag">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="✕" Click="OnCancelClick"
                            Style="{StaticResource CloseButton}" />
                    <TextBlock x:Name="TitleText" Text="选择"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                               FontWeight="SemiBold" Padding="12,8" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Top" Padding="10,8,10,4">
                <TextBox x:Name="SearchBox"
                         Background="#22000000" Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                         CaretBrush="{StaticResource AccentBrush}"
                         Padding="4,4" FontSize="12"
                         TextChanged="OnSearchTextChanged" />
            </Border>

            <Border DockPanel.Dock="Bottom" Background="#FF12122A"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="10,6">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="清除选择" Click="OnClearClick"
                            Padding="10,4" FontSize="12" Cursor="Hand"
                            Background="#22FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="HintText" Text=""
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <ListBox x:Name="ItemsList" Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single"
                     SelectionChanged="OnItemSelected">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#22FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#334FC3F7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <Border DockPanel.Dock="Left" Width="32" Height="32" Margin="0,0,8,0"
                                    Background="#22FFFFFF" CornerRadius="3" ClipToBounds="True">
                                <Image Source="{Binding IconPath, Converter={StaticResource PathToImage}}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding RightLabel}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="8,0,2,0"
                                       TextAlignment="Right" />
                            <TextBlock Text="{Binding Display}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
