<UserControl x:Class="ASPAssistant.App.Views.OperatorBrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ASPAssistant.App.Controls"
             xmlns:converters="clr-namespace:ASPAssistant.App.Converters"
             Background="{StaticResource PanelBackgroundBrush}">
    <UserControl.Resources>
        <converters:NullToStringConverter x:Key="NullToAll" />
    </UserControl.Resources>
    <DockPanel>
        <!-- Search box -->
        <Border DockPanel.Dock="Top" Margin="8,8,8,4"
                Background="#FF1E1E38" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                     BorderThickness="0" Padding="8,5"
                     CaretBrush="{StaticResource AccentBrush}" />
        </Border>

        <!-- Filter panel -->
        <Expander DockPanel.Dock="Top" Margin="8,0,8,4"
                  Foreground="{StaticResource TextSecondaryBrush}" IsExpanded="False">
            <Expander.Header>
                <TextBlock Text="筛选" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
            </Expander.Header>
            <StackPanel Margin="0,6,0,2">
                <TextBlock Text="等阶" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,4" />
                <ListBox x:Name="TierFilterList"
                         Style="{StaticResource FilterChipListBox}"
                         ItemsSource="{Binding AvailableTiers}"
                         PreviewMouseLeftButtonDown="OnFilterListPreviewMouseDown"
                         SelectionChanged="OnTierFilterChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource NullToAll}, ConverterParameter=全部}"
                                       FontSize="11" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="盟约" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,6,0,4" />
                <ListBox x:Name="CovenantFilterList"
                         SelectionMode="Multiple"
                         Style="{StaticResource FilterChipListBox}"
                         ItemsSource="{Binding AvailableCovenants}"
                         PreviewMouseLeftButtonDown="OnCovenantPreviewMouseDown"
                         SelectionChanged="OnCovenantFilterChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource NullToAll}, ConverterParameter=全部}"
                                       FontSize="11" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="词条" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,6,0,4" />
                <ListBox x:Name="TraitFilterList"
                         Style="{StaticResource FilterChipListBox}"
                         ItemsSource="{Binding AvailableTraitTypes}"
                         PreviewMouseLeftButtonDown="OnFilterListPreviewMouseDown"
                         SelectionChanged="OnTraitFilterChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource NullToAll}, ConverterParameter=全部}"
                                       FontSize="11" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Expander>

        <!-- Operator list (virtualized: ScrollViewer lives inside the template so WPF can recycle cards) -->
        <ItemsControl ItemsSource="{Binding FilteredOperators}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel">
            <ItemsControl.Template>
                <ControlTemplate TargetType="ItemsControl">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="True"
                                  Focusable="False">
                        <ItemsPresenter Margin="8,0,8,8" />
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:OperatorCard TrackingToggled="OnOperatorTrackingToggled" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
