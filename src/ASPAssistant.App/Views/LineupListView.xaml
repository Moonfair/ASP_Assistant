<UserControl x:Class="ASPAssistant.App.Views.LineupListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ASPAssistant.App.Converters"
             xmlns:models="clr-namespace:ASPAssistant.Core.Models;assembly=ASPAssistant.Core"
             Background="{StaticResource PanelBackgroundBrush}">
    <UserControl.Resources>
        <converters:LocalPathToImageConverter x:Key="PathToImage" />

        <!-- Top buttons (new / import) -->
        <Style x:Key="LineupTopButton" TargetType="Button" BasedOn="{StaticResource ClickableButtonBase}">
            <Setter Property="Background" Value="#1A4FC3F7" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#334FC3F7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#334FC3F7" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#444FC3F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card-bottom small button (edit / share / track / delete) -->
        <Style x:Key="LineupCardActionButton" TargetType="Button" BasedOn="{StaticResource ClickableButtonBase}">
            <Setter Property="Background" Value="#0AFFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LineupCardStyle" TargetType="Border" BasedOn="{StaticResource ItemCardBorder}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="#FF2A2A48" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Top button row -->
        <Border DockPanel.Dock="Top" Background="#11000000" Padding="12,10">
            <DockPanel>
                <TextBlock Text="我的阵容" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                           Margin="0,0,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ 新建" Style="{StaticResource LineupTopButton}"
                            Click="OnNewLineup" />
                    <Button Content="↓ 导入" Style="{StaticResource LineupTopButton}"
                            Margin="8,0,0,0" Click="OnImportLineup" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Lineup list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,6">
            <Grid>
                <TextBlock x:Name="EmptyHint"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" Margin="0,40,0,0"
                           Visibility="Collapsed">
                    <Run Text="暂无阵容" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" /><LineBreak />
                    <Run Text="点击上方“新建”或“导入”开始创建" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                </TextBlock>

                <ItemsControl x:Name="LineupItems" ItemsSource="{Binding Lineups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Lineup}">
                            <Border Style="{StaticResource LineupCardStyle}" Tag="{Binding Id}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header: Name + Badge -->
                                    <DockPanel Grid.Row="0">
                                        <Border DockPanel.Dock="Right"
                                                Background="#1A4FC3F7"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Tag="{Binding Id}"
                                                       Loaded="OnCovenantBadgeLoaded"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10" FontWeight="Bold" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,8,0" />
                                    </DockPanel>

                                    <!-- Body: Icons -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Slots}" Margin="0,10,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:LineupSlot}">
                                                <Border Width="34" Height="34" Margin="0,0,5,5"
                                                        CornerRadius="4" Background="#1AFFFFFF"
                                                        BorderBrush="#11FFFFFF" BorderThickness="1"
                                                        ClipToBounds="True"
                                                        ToolTip="{Binding OperatorName}">
                                                    <Image Stretch="UniformToFill"
                                                           Tag="{Binding OperatorName}"
                                                           Loaded="OnSlotIconLoaded" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Footer: Actions -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Button Content="编辑" Tag="{Binding Id}"
                                                Style="{StaticResource LineupCardActionButton}"
                                                Click="OnEditLineup" />
                                        <Button Content="分享" Tag="{Binding Id}"
                                                Style="{StaticResource LineupCardActionButton}"
                                                Click="OnShareLineup" />
                                        <Button Content="追踪" Tag="{Binding Id}"
                                                Style="{StaticResource LineupCardActionButton}"
                                                Click="OnTrackLineup" />
                                        <Button Content="删除" Tag="{Binding Id}"
                                                Style="{StaticResource LineupCardActionButton}"
                                                Foreground="#CCFF6666"
                                                Click="OnDeleteLineup" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
